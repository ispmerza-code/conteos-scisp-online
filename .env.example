# ============================================================
# Variables de entorno — Backend FastAPI (ConteosApi)
# Copia este archivo a .env para desarrollo local.
# En Railway, configura estas variables en: Proyecto → Variables
# ============================================================

# ---- BASE DE DATOS ----
# Railway MySQL: mysql+pymysql://usuario:password@host:puerto/nombre_bd
# (Railway genera DATABASE_URL en formato mysql://, debes cambiar a mysql+pymysql://)
# Base de datos externa (PlanetScale, TiDB, etc.): igual formato
DATABASE_URL=mysql+pymysql://tu_usuario:tu_password@tu_host:3306/siniestros_scisp

# ---- SEGURIDAD ----
# Genera una clave segura con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=genera_una_clave_secreta_muy_segura_de_al_menos_32_caracteres
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ---- CORS ----
# Orígenes permitidos separados por coma. Usa * para permitir todos (solo desarrollo).
# Ejemplo para producción: https://tu-app.vercel.app,https://otro-dominio.com
ALLOWED_ORIGINS=https://tu-app.vercel.app

# ---- CONFIGURACIÓN DE LA APLICACIÓN ----
PROJECT_NAME=API Conteos SCISP
PROJECT_VERSION=1.0.0

# ---- SERVIDOR (opcional) ----
HOST=0.0.0.0
PORT=8000

# ---- LOGS (opcional) ----
LOG_LEVEL=info
